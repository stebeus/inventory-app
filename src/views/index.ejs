<!doctype html>
<html lang="en">
	<%- include('partials/metadata', { title }) %>
	<body>
		<div id="root">
			<%- include('partials/navbar', { title }) %>
			<main>
				<ul class="tabs">
					<% for (const { id, name, img_url } of categories) { %>
					<li class="tab">
						<%- include('partials/img-link', { href: `/categories/${id}/`, name,
						img_url }) %>
					</li>
					<% } %>
				</ul>

				<form class="search" action="/search" method="get">
					<label>
						Search items:
						<input type="search" name="q" />
					</label>
				</form>

				<div class="grid">
					<% for (const { id, name, img_url } of items) { %>
					<div class="cell">
						<%- include('partials/img-link', { href: `item/${id}`, name, img_url
						}) %>
					</div>
					<% } %>
				</div>
			</main>
			<%- include('partials/footer', { title }) %>
		</div>
	</body>
</html>
